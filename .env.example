# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/newsresearcher

# API authentication (required)
API_KEY=changeme_generate_a_secure_random_key

# Hacker News (Algolia API — no credentials required)
HN_KEYWORDS=ai agent,LLM,RAG,MCP,multi-agent,AutoGen,LangChain
HN_FETCH_LIMIT=100

# Reddit (public JSON API — no credentials required)
REDDIT_SUBREDDITS=MachineLearning,LocalLLaMA,singularity,artificial
REDDIT_KEYWORDS=
REDDIT_FETCH_LIMIT=100

# GitHub (optional token raises rate limit from 10 to 30 rpm)
GITHUB_MONITORED_REPOS=langchain-ai/langchain,microsoft/autogen,ollama/ollama,ggerganov/llama.cpp
GITHUB_KEYWORDS=ai agent,llm,rag
GITHUB_FETCH_LIMIT=30
GITHUB_TOKEN=

# SMTP / email digest (optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
DIGEST_EMAIL_FROM=noreply@example.com
DIGEST_EMAIL_TO=team@example.com

# Webhook digest (optional)
DIGEST_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Scheduler config
FETCH_INTERVAL_MINUTES=15
DIGEST_CRON=0 8 * * *

# Relevance scoring
RELEVANCE_THRESHOLD=5
KEYWORDS_CONFIG_PATH=keywords.yaml

# Gemini AI Summarizer (optional — Chinese daily report, disabled if key absent)
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
SUMMARY_POST_LIMIT=20

# Groq AI Summarizer (optional — takes priority over Gemini if both set)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Daily briefing output directory (relative to repo root)
BRIEFINGS_OUTPUT_DIR=briefings

# Digest lookback / catch-up
DIGEST_LOOKBACK_HOURS=48
CATCHUP_MAX_DAYS=7

# ArXiv fetcher (v2)
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL
ARXIV_MAX_RESULTS=50

# v2 Feature flags (all default False — enable one by one after migration)
FEATURE_ARXIV_FETCHER=false
FEATURE_FTS_SEARCH=false
FEATURE_WEEKLY_BRIEFING=false
FEATURE_HIGHLIGHT_SCORER=false
FEATURE_BOOKMARKS=false

# Personalization: inject current work context into daily briefing LLM prompt
# Example: USER_CONTEXT=I am building a RAG pipeline with LangChain and pgvector
USER_CONTEXT=

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=changeme_generate_a_secure_random_key
